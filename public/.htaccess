# Control de la memòria cau del servidor (Hostinger/LiteSpeed).
#
# Problema que resol: per defecte el servidor serveix els .js i .json amb
# "max-age=604800" (7 dies). Els fitxers de DADES de l'edició canvien 4 cops
# al dia, i una còpia envellida a la cau feia que la portada mostrés
# l'edició anterior encara que el desplegament hagués anat bé.
#
# Regla: les dades de l'edició es revaliden sempre (no-cache fa servir
# Last-Modified i respon 304 si no hi ha canvis: barat i sempre fresc).
# Les imatges i els àudios, que no canvien mai un cop publicats, poden
# quedar-se a la cau tant de temps com calgui.

<IfModule mod_headers.c>
  <FilesMatch "^(news|radar|analysis|reflection|daily-image)\.js$">
    Header set Cache-Control "no-cache, must-revalidate"
  </FilesMatch>
  <FilesMatch "\.json$">
    Header set Cache-Control "no-cache, must-revalidate"
  </FilesMatch>
  <FilesMatch "\.(html|php)$">
    Header set Cache-Control "no-cache, must-revalidate"
  </FilesMatch>
  <FilesMatch "\.(jpg|jpeg|png|webp|gif|svg|mp3)$">
    Header set Cache-Control "public, max-age=2592000, immutable"
  </FilesMatch>
</IfModule>

<IfModule mod_rewrite.c>
  RewriteEngine On

  # Un únic host canònic per evitar duplicats www/no-www.
  RewriteCond %{HTTP_HOST} ^www\.inteligencia-artificial\.cat$ [NC]
  RewriteRule ^ https://inteligencia-artificial.cat%{REQUEST_URI} [R=301,L]

  RewriteRule ^sitemap\.xml$ sitemap.php [L]
  RewriteRule ^news-sitemap\.xml$ news-sitemap.php [L]
  RewriteRule ^feed\.xml$ feed.php [L]
  RewriteRule ^tema/([a-z0-9-]+)/?$ tema.php?tema=$1 [L,QSA]

  # URLs antigues: cada pàgina es redirigeix al nou equivalent temàtic.
  RewriteRule ^ara/?$ https://inteligencia-artificial.cat/ [R=301,L]
  RewriteRule ^onu/?$ https://inteligencia-artificial.cat/tema/politica-i-governanca [R=301,L]
  RewriteRule ^economia/?$ https://inteligencia-artificial.cat/tema/empresa-i-treball [R=301,L]
  RewriteRule ^llms/?$ https://inteligencia-artificial.cat/tema/tecnologia [R=301,L]
  RewriteRule ^computacio/?$ https://inteligencia-artificial.cat/tema/infraestructura-i-energia [R=301,L]
  RewriteRule ^ia-i-politica/?$ https://inteligencia-artificial.cat/tema/politica-i-governanca [R=301,L]
  RewriteRule ^ia-i-innovacio/?$ https://inteligencia-artificial.cat/tema/tecnologia [R=301,L]
  RewriteRule ^ia-i-societat/?$ https://inteligencia-artificial.cat/tema/societat-i-cultura [R=301,L]
  RewriteRule ^ia-i-filosofia/?$ https://inteligencia-artificial.cat/tema/societat-i-cultura [R=301,L]
  RewriteRule ^ia-i-educacio/?$ https://inteligencia-artificial.cat/dossiers.html [R=301,L]
  RewriteRule ^ia-i-medi-ambient/?$ https://inteligencia-artificial.cat/tema/infraestructura-i-energia [R=301,L]
  RewriteRule ^salutia/?$ https://inteligencia-artificial.cat/tema/societat-i-cultura [R=301,L]
  RewriteRule ^tv3/?$ https://inteligencia-artificial.cat/tema/catalunya [R=301,L]
  RewriteRule ^generalitat-de-catalunya/?$ https://inteligencia-artificial.cat/dossiers.html [R=301,L]
  RewriteRule ^formacio/?$ https://inteligencia-artificial.cat/eines.html [R=301,L]
  RewriteRule ^llibres-tecnics/?$ https://inteligencia-artificial.cat/dossiers.html [R=301,L]
</IfModule>
